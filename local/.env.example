# Service storage. Paths can be absolute or relative to this repository.
VIDEO_GEN_ROOT=.
DATA_DIR=data
WORK_DIR=work
OUT_DIR=out

CORS_ORIGINS=http://localhost:3000

# Binaries. Use absolute paths on Windows when they are not on PATH.
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# MuseTalk 1.5 installation. The Python executable must be from MuseTalk's own venv.
MUSE_TALK_ROOT=vendor/MuseTalk
MUSE_TALK_PYTHON=
MUSE_TALK_BBOX_SHIFT=0
# Safe starting point for 4GB RTX 3050-class GPUs.
MUSE_TALK_BATCH_SIZE=1
MUSE_TALK_USE_FLOAT16=true

# CUDA is mandatory: the MuseTalk launcher fails instead of falling back to CPU.
# The allocator uses the lower of GPU_MEMORY_LIMIT_MB and GPU_MEMORY_FRACTION.
GPU_INDEX=0
GPU_MEMORY_LIMIT_MB=3500
GPU_MEMORY_FRACTION=0.90

# Set to true only after adding a closed-mouth driver video and installing LivePortrait.
ENABLE_LIVEPORTRAIT=false
LIVEPORTRAIT_ROOT=vendor/LivePortrait
LIVEPORTRAIT_PYTHON=
IDLE_DRIVER_PATH=assets/drivers/neutral_subtle.mp4
AVATAR_MOTION_SECONDS=30

# basic validates image dimensions. insightface also rejects no-face, multi-face, tiny-face,
# and strongly turned faces; it requires the optional face-validation dependencies.
FACE_VALIDATION=basic
MAX_UPLOAD_MB=50
MAX_AUDIO_SECONDS=120
KEEP_WORKDIRS=false
