# Copy to .env and fill in the three REQUIRED keys below. Everything else has a
# working default. On Streamlit Community Cloud, put these in Settings -> Secrets
# in TOML form instead (see .streamlit/secrets.toml.example) - app.py bridges them
# into env vars on startup, so both paths behave identically.

# ---------------------------------------------------------------------------
# REQUIRED - the app refuses to start without these three
# ---------------------------------------------------------------------------

# https://platform.openai.com/api-keys - powers every agent (research + script)
OPENAI_API_KEY=your_openai_api_key

# https://platform.composio.dev - brokers YouTube, Twitter/X, Exa, and HeyGen
COMPOSIO_API_KEY=your_composio_api_key

# https://dashboard.sarvam.ai - text-to-speech, called directly (not via Composio)
SARVAM_API_KEY=your_sarvam_api_key

# ---------------------------------------------------------------------------
# OpenAI
# ---------------------------------------------------------------------------

OPENAI_MODEL=gpt-4o

# ---------------------------------------------------------------------------
# Composio
# ---------------------------------------------------------------------------

# Must match the user you connected the toolkits under in the Composio dashboard.
# Leave as default-user unless you connected them under a different id.
COMPOSIO_USER_ID=default-user

# Optional. Omit to use whichever account is connected by default for each
# toolkit; set them to pin a specific auth config from the Composio dashboard.
YOUTUBE_AUTH_CONFIG_ID=
EXA_AUTH_CONFIG_ID=
HEYGEN_AUTH_CONFIG_ID=

# ---------------------------------------------------------------------------
# Twitter/X (twscrape) - direct scraping, NOT Composio. Optional; empty = skipped.
# ---------------------------------------------------------------------------

# Cookies from a logged-in X account: open x.com -> DevTools -> Application ->
# Cookies, copy auth_token and ct0. Format: "auth_token=...; ct0=..."
TWITTER_COOKIES=

# ---------------------------------------------------------------------------
# Reddit (PRAW, read-only) - direct API, NOT Composio. Optional; empty = skipped.
# ---------------------------------------------------------------------------

# Create a "script" app at https://www.reddit.com/prefs/apps for id + secret.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=videogen-research/1.0

# ---------------------------------------------------------------------------
# Sarvam AI (text-to-speech)
# ---------------------------------------------------------------------------

# bulbul:v2 (1500 char limit) or bulbul:v3 (2500 char limit).
SARVAM_MODEL=bulbul:v2

# Speakers are model-specific - a v2 speaker on v3 will fail.
#   bulbul:v2  female: anushka, manisha, vidya, arya
#              male:   abhilash, karun, hitesh
#   bulbul:v3  shubh (default), aditya, ritu, priya, neha, rahul, pooja, kavya, ...
SARVAM_SPEAKER=anushka

# One of: en-IN, hi-IN, bn-IN, gu-IN, kn-IN, ml-IN, mr-IN, od-IN, pa-IN, ta-IN, te-IN
SARVAM_LANGUAGE=en-IN

# ---------------------------------------------------------------------------
# Public URL (required for video, ignored for everything else)
# ---------------------------------------------------------------------------

# Generated audio is written to static/, which Streamlit serves over HTTP, and
# HeyGen fetches it from this origin. Leave EMPTY locally: HeyGen cannot reach
# localhost, so the video stage only works deployed. Set it to your app's real
# URL after the first deploy, then reboot the app.
PUBLIC_BASE_URL=

# ---------------------------------------------------------------------------
# HeyGen (avatar video)
# ---------------------------------------------------------------------------

HEYGEN_AVATAR_ID=109cdee34a164003b0e847ffce93828e

# Polling budget: interval x attempts is the longest the app waits for a render.
# The defaults below block the UI for up to 15 minutes before timing out.
HEYGEN_POLLING_INTERVAL_SECONDS=15
HEYGEN_MAX_POLLING_ATTEMPTS=60
