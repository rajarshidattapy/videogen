# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# Composio
COMPOSIO_API_KEY=your_composio_api_key
COMPOSIO_USER_ID=your_user_id

# Auth Config IDs (from the Composio dashboard) - optional
YOUTUBE_AUTH_CONFIG_ID=your_youtube_auth_config_id
TWITTER_AUTH_CONFIG_ID=your_twitter_auth_config_id
EXA_AUTH_CONFIG_ID=your_exa_auth_config_id
HEYGEN_AUTH_CONFIG_ID=your_heygen_auth_config_id

# Sarvam AI text-to-speech (direct API key from https://dashboard.sarvam.ai)
SARVAM_API_KEY=your_sarvam_api_key
SARVAM_MODEL=bulbul:v2
SARVAM_SPEAKER=anushka
SARVAM_LANGUAGE=en-IN

# Public origin of the deployed app - HeyGen fetches the audio from here.
# Leave empty locally; set it after deploying, e.g. https://yourapp.streamlit.app
PUBLIC_BASE_URL=

# HeyGen avatar and polling
HEYGEN_AVATAR_ID=109cdee34a164003b0e847ffce93828e
HEYGEN_POLLING_INTERVAL_SECONDS=15
HEYGEN_MAX_POLLING_ATTEMPTS=60
